# FACE Symcon MCP Server – Konfiguration
# Diese Datei neben dem Server (bzw. der .exe) ablegen und ausfüllen.
# Bereits gesetzte Umgebungsvariablen haben Vorrang vor dieser Datei.

# Port des MCP-Servers
MCP_PORT=4096

# Symcon JSON-RPC API (mit abschließendem Slash). <SYMBOX-IP> ersetzen.
SYMCON_API_URL=http://<SYMBOX-IP>:3777/api/

# Pflicht, sobald der Server im Netz erreichbar ist (MCP_BIND=0.0.0.0).
# Langer Zufallsstring – derselbe Wert muss am Mac in Claude Desktop als BEARER_TOKEN stehen.
MCP_AUTH_TOKEN=

# Dev-Tools (Skript lesen + PHP mit Ausgabe ausführen). NUR auf Dev-/Test-SymBox auf 1 setzen.
MCP_DEV_TOOLS=1

# Bind-Adresse. 0.0.0.0 = im Netz erreichbar (Standard). 127.0.0.1 = nur lokal (kein Token nötig).
MCP_BIND=0.0.0.0

# Optional: wenn die Symcon-API einen Login verlangt (Remote Access Basic-Auth)
# SYMCON_API_USER=lizenz-email@example.com
# SYMCON_API_PASSWORD=
